# Orchestra-Core API — environment variables
# Copy this file to .env and fill in your credentials
# Never commit .env to git

# Server
PORT=3001
NODE_ENV=development

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_random_bytes_hex

# Supabase — create a project at supabase.com, find these in Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# IntaSend — register at intasend.com, find in Dashboard → Settings → API Keys
# Use test keys for sandbox, live keys for production
INTASEND_PUBLISHABLE_KEY=IS_PK_test_xxxxxxxxxxxx
INTASEND_SECRET_KEY=IS_SK_test_xxxxxxxxxxxx
# Set this same string in IntaSend Dashboard → Webhooks → Secret
INTASEND_WEBHOOK_SECRET=your-webhook-secret

# Africa's Talking — register at africastalking.com (sandbox free, production needs approval)
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox   # change to your registered username in production

# Resend — register at resend.com, free tier includes 3000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Orchestra-Core <onboarding@resend.dev>

# Your deployed frontend URL (used in payment redirect and email links)
FRONTEND_URL=http://localhost:5173

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://localhost:8080
