# Environment files — never commit real credentials
.env
.env.local
.env.*.local
backend/.env
backend/.env.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
server/node_modules
dist
dist-ssr
release
release2
release*/
*.local

# Android build outputs (source code committed, compiled output is not)
android/.gradle/
android/build/
android/app/build/
android/.idea/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Word lock files
~$*

# Personal business documents — not for the public repo
/*.docx
/*.pdf

# Superseded curriculum drafts — canonical content lives in content/lessons/
/Curriculum/

# Marketing-only logo variants — not used by the website/app build
/logo-instagram.png

# Scratch notes containing live credentials — never commit
/Orchestra-Core.txt
