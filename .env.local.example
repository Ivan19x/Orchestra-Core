# Frontend environment — copy to .env.local and fill in
# Vite only exposes VITE_* variables to the browser

# URL of your deployed backend API
# In development, point to the local backend (cd backend && npm run dev)
VITE_API_URL=http://localhost:3001

# In production:
# VITE_API_URL=https://api.orchestracore.com

# Installer download URLs — set these once you've uploaded the built installer
# Recommended: use GitHub Release assets (free, reliable, versioned)
# Example after uploading via the release workflow:
# VITE_DOWNLOAD_URL_WIN=https://github.com/YOUR_USER/orchestra-core/releases/download/v1.0.0/Orchestra-Core-Setup-1.0.0.exe
# VITE_DOWNLOAD_URL_MAC=https://github.com/YOUR_USER/orchestra-core/releases/download/v1.0.0/Orchestra-Core-1.0.0.dmg
VITE_DOWNLOAD_URL_WIN=
VITE_DOWNLOAD_URL_MAC=
